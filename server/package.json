{
  "name": "chess-webapp-server",
  "version": "1.0.0",
  "description": "Express + Socket.IO backend for the Chess Webapp",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OneAutumnLeaf4700/Chess-Webapp"
  },
  "author": "Rayyan",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "mongoose": "^8.12.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "*.js",
      "!server.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/",
      "/database/"
    ]
  }
}
